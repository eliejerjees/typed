# OpenAI — for final result generation
OPENAI_API_KEY=sk-...

# Last.fm — Client Credentials flow (no user OAuth needed)
# Create an app at https://www.last.fm/api
LASTFM_API_KEY=your_client_id_here
LASTFM_SHARED_SECRET=your_client_secret_here


# TMDB — The Movie Database
# Get a free key at https://www.themoviedb.org/settings/api (v3 API key)
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_READ_KEY=your_tmdb_read_key_here